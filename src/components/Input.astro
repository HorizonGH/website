---
interface Props {
  type?: 'text' | 'email' | 'password' | 'search' | 'url' | 'tel';
  name?: string;
  id?: string;
  placeholder?: string;
  value?: string;
  required?: boolean;
  class?: string;
}

const {
  type = 'text',
  name,
  id,
  placeholder = '',
  value,
  required = false,
  class: className = ''
} = Astro.props;

const baseStyles =
  'h-11 w-full rounded-xl border border-outline-variant/35 bg-surface-container-low px-4 text-sm text-on-surface placeholder:text-on-surface-variant/70 transition-colors duration-200 focus-visible:outline-none focus-visible:border-primary/60 focus-visible:ring-2 focus-visible:ring-primary/30';
---

<input
  type={type}
  name={name}
  id={id}
  placeholder={placeholder}
  value={value}
  required={required}
  class:list={[baseStyles, className]}
/>
