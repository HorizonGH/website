---
import Layout from '../../layouts/Layout.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { useTranslations } from '../../i18n/utils';
const t = useTranslations('es') as any;
---


<Layout locale="es" title={t.seo.contact_title}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap" rel="stylesheet">

  <div class="min-h-screen bg-white text-black font-sans relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-5 z-0" 
         style="background-image: radial-gradient(#00E5FF 1px, transparent 1px), radial-gradient(#00E5FF 1px, transparent 1px); background-size: 40px 40px; background-position: 0 0, 20px 20px;">
    </div>

    <!-- Header -->
    <header class="relative z-10 container mx-auto px-6 py-6 flex items-center justify-between">
      <div class="text-2xl font-bold tracking-tighter">
        <a href="/es/">Horizon <span class="text-[#00E5FF] font-['Caveat'] text-3xl">-gh</span></a>
      </div>
      <div class="flex items-center space-x-4 md:space-x-8">
        <nav class="hidden md:flex space-x-8 text-sm font-medium tracking-wide">
          <a href="/es/" class="hover:text-[#00E5FF] transition-colors">{t.nav.home}</a>
          <a href="/es/services" class="hover:text-[#00E5FF] transition-colors">{t.nav.services}</a>
          <a href="/es/blog" class="hover:text-[#00E5FF] transition-colors">{t.nav.blog}</a>
          <a href="/es/contact" class="hover:text-[#00E5FF] transition-colors">{t.nav.contact}</a>
        </nav>
        <div class="flex items-center ml-4 z-50">
          <LanguageSwitcher currentUrl={Astro.url} />
        </div>
      </div>
    </header>

    <!-- Contact Head -->
    <section class="relative z-10 container mx-auto px-6 pt-24 pb-12 text-center">
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-tight mb-6">
        {t.contact_page.hero_title} <span class="text-[#00E5FF] font-['Caveat'] text-6xl md:text-8xl italic font-normal">{t.contact_page.hero_emphasis}</span>
      </h1>
      <div class="w-24 h-1 bg-[#00E5FF] mx-auto mb-8"></div>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto font-light">
        {t.contact_page.hero_subtitle}
      </p>
    </section>

    <!-- Main Content -->
    <section class="pb-32 bg-white relative z-10">
      <div class="container mx-auto px-6 max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          
          <!-- Contact Info Box -->
          <div class="bg-gray-50 border border-gray-100 p-12 rounded-3xl relative overflow-hidden">
            <div class="absolute -right-8 -top-8 w-40 h-40 bg-[#00E5FF]/10 rounded-full blur-3xl"></div>
            
            <h3 class="text-3xl font-black mb-8">{t.contact_page.info_title}</h3>
            <div class="space-y-8 relative z-10">
              <div class="flex items-start gap-6">
                <div class="w-12 h-12 bg-white border-2 border-[#00E5FF] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold tracking-widest uppercase text-sm mb-1 text-gray-500">{t.contact_page.location_label}</h4>
                  <p class="text-lg font-medium">{t.contact_page.location_value}<br/>{t.contact_page.location_subvalue}</p>
                </div>
              </div>
              
              <div class="flex items-start gap-6">
                <div class="w-12 h-12 bg-white border-2 border-[#00E5FF] rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold tracking-widest uppercase text-sm mb-1 text-gray-500">{t.contact_page.email_label}</h4>
                  <p class="text-lg font-medium">hello@horizon.gh</p>
                </div>
              </div>
            </div>
            
            <div class="mt-12 pt-8 border-t border-gray-200">
              <div class="flex items-center gap-2 mb-4">
                <span class="w-3 h-3 rounded-full bg-[#00E5FF] animate-pulse"></span>
                <span class="text-sm font-bold tracking-widest uppercase text-gray-500">{t.contact_page.availability}</span>
              </div>
            </div>
          </div>

          <!-- Extended Contact Form -->
          <div class="bg-white rounded-3xl border border-gray-200 p-12 shadow-[0_10px_50px_rgba(0,0,0,0.05)]">
            <h3 class="text-3xl font-black mb-8">{t.contact_page.form_title}</h3>
            <form class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-bold tracking-widest uppercase text-gray-500 mb-2">{t.contact_page.form_name}</label>
                  <input type="text" class="w-full bg-gray-50 border-2 border-gray-100 text-black px-4 py-4 rounded-xl focus:outline-none focus:border-[#00E5FF] focus:bg-white transition-colors" placeholder={t.contact_page.form_name_placeholder}>
                </div>
                <div>
                  <label class="block text-xs font-bold tracking-widest uppercase text-gray-500 mb-2">{t.contact_page.form_email}</label>
                  <input type="email" class="w-full bg-gray-50 border-2 border-gray-100 text-black px-4 py-4 rounded-xl focus:outline-none focus:border-[#00E5FF] focus:bg-white transition-colors" placeholder={t.contact_page.form_email_placeholder}>
                </div>
              </div>
              <div>
                <label class="block text-xs font-bold tracking-widest uppercase text-gray-500 mb-2">{t.contact_page.form_scope}</label>
                <select class="w-full bg-gray-50 border-2 border-gray-100 text-black px-4 py-4 rounded-xl focus:outline-none focus:border-[#00E5FF] focus:bg-white transition-colors appearance-none">
                  <option value="">{t.contact_page.form_scope_placeholder}</option>
                  <option value="web">{t.contact_page.form_scope_web}</option>
                  <option value="software">{t.contact_page.form_scope_software}</option>
                  <option value="other">{t.contact_page.form_scope_other}</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold tracking-widest uppercase text-gray-500 mb-2">{t.contact_page.form_details}</label>
                <textarea rows="5" class="w-full bg-gray-50 border-2 border-gray-100 text-black px-4 py-4 rounded-xl focus:outline-none focus:border-[#00E5FF] focus:bg-white transition-colors resize-none" placeholder={t.contact_page.form_details_placeholder}></textarea>
              </div>
              <button type="submit" class="w-full bg-black text-white hover:bg-[#00E5FF] hover:text-black font-bold py-4 px-8 rounded-xl transition-all duration-300 shadow-[0_10px_20px_rgba(0,0,0,0.1)] hover:shadow-[0_10px_20px_rgba(0,229,255,0.3)] text-lg">
                {t.contact_page.form_submit}
              </button>
            </form>
          </div>

        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black text-white py-20 border-t-4 border-[#00E5FF] relative z-10">
      <div class="container mx-auto px-6 text-center">
        <div class="text-3xl font-bold mb-6">
          Horizon <span class="text-[#00E5FF] font-['Caveat'] text-4xl ml-1">-gh</span>
        </div>
        <p class="text-gray-400 mb-8 max-w-sm mx-auto">
          {t.contact_page.footer_description}
        </p>
        <p class="text-sm text-gray-500">
          &copy; {new Date().getFullYear()} Horizon gh. {t.contact_page.footer_rights}
        </p>
      </div>
    </footer>
  </div>
</Layout>
