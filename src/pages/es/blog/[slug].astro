---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog_es');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content } = await render(post);
const formatDate = (date: Date) =>
  date.toLocaleDateString('es-ES', { month: 'long', day: '2-digit', year: 'numeric' });
---

<Layout title={`${post.data.title} | Horizon.gh`} locale="es">
  <main class="pt-24 sm:pt-28 pb-20">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(76,214,251,0.14),_transparent_28%),radial-gradient(circle_at_bottom_right,_rgba(255,255,255,0.08),_transparent_24%)] pointer-events-none"></div>
      <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
        <div class="relative overflow-hidden rounded-[2rem] border border-surface-container-highest bg-surface-container p-8 shadow-ambient">
          <div class="absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-surface-container-high/90 to-transparent pointer-events-none"></div>

          <div class="relative z-10 space-y-6">
            <a class="inline-flex items-center gap-2 text-accent-cyan text-sm uppercase tracking-[0.28em] font-label hover:text-primary transition-colors" href="/es/blog">
              <span class="material-symbols-outlined text-base">arrow_back</span>
              Volver a perspectivas
            </a>

            <div class="flex flex-wrap items-center gap-3 sm:gap-4">
              <span class="px-3 py-1.5 rounded-full glass-panel text-tertiary text-xs sm:text-sm font-bold tracking-widest uppercase">
                {post.data.category}
              </span>
              <span class="px-3 py-1.5 rounded-full glass-panel text-on-surface-variant text-xs sm:text-sm font-label">
                {post.data.readTime}
              </span>
              <span class="text-on-surface-variant text-xs sm:text-sm font-label">
                {formatDate(post.data.date)}
              </span>
            </div>

            <div class="max-w-3xl">
              <h1 class="text-4xl sm:text-5xl md:text-6xl font-display font-bold text-on-surface tracking-tight">
                {post.data.title}
              </h1>
              <p class="mt-4 text-lg sm:text-xl text-on-surface-variant leading-relaxed">
                {post.data.excerpt}
              </p>
            </div>

            <div class="grid gap-6 lg:grid-cols-[auto_280px] items-start">
              <div class="flex items-center gap-4 bg-surface-container-highest rounded-3xl p-4 border border-surface-container-high">
                <div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center text-primary font-display font-bold">
                  {post.data.author
                    .split(' ')
                    .map((word: string) => word[0])
                    .join('')}
                </div>
                <div>
                  <p class="text-on-surface font-display font-bold">{post.data.author}</p>
                  <p class="text-on-surface-variant text-sm font-label">{post.data.category}</p>
                </div>
              </div>

              <div class="rounded-3xl overflow-hidden border border-surface-container-highest bg-surface-container-high p-6">
                <div class="text-xs uppercase tracking-[0.28em] text-on-surface-variant font-label mb-3">Destacado</div>
                <p class="text-sm leading-6 text-on-surface-variant">
                  Una experiencia de lectura inmersiva que combina el estilo visual del sitio con una presentación clara del contenido técnico.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-4 sm:px-6 mt-12 grid gap-10 lg:grid-cols-[minmax(0,1fr)_280px]">
      <article class="rounded-[2rem] border border-surface-container-highest bg-surface-container-low p-10 shadow-ambient overflow-hidden">
        <div class="relative overflow-hidden rounded-[2rem] mb-10">
          <img
            alt={post.data.title}
            class="w-full h-[420px] object-cover"
            src={post.data.coverImage}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/10 to-transparent"></div>
        </div>

        <div class="blog-content">
          <Content />
        </div>
      </article>

      <aside class="space-y-6">
        <div class="rounded-[2rem] border border-surface-container-highest bg-surface-container-high p-6 shadow-ambient">
          <h2 class="text-lg font-display font-bold text-on-surface mb-4">Detalles del artículo</h2>
          <div class="space-y-3 text-sm text-on-surface-variant">
            <div>
              <p class="font-semibold text-on-surface">Categoría</p>
              <p>{post.data.category}</p>
            </div>
            <div>
              <p class="font-semibold text-on-surface">Tiempo de lectura</p>
              <p>{post.data.readTime}</p>
            </div>
            <div>
              <p class="font-semibold text-on-surface">Publicado</p>
              <p>{formatDate(post.data.date)}</p>
            </div>
          </div>
        </div>

        <div class="rounded-[2rem] border border-surface-container-highest bg-surface-container-high p-6 shadow-ambient">
          <h2 class="text-lg font-display font-bold text-on-surface mb-4">Relacionado</h2>
          <p class="text-sm text-on-surface-variant">
            Visita la página de perspectivas para ver más artículos y descubrimientos de ingeniería digital.
          </p>
        </div>
      </aside>
    </section>
  </main>

  <footer class="w-full border-t border-slate-800/30 bg-surface">
    <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="text-xl font-bold text-primary mb-4 font-display">Horizon.gh</div>
        <p class="font-body text-sm text-slate-400 max-w-xs">
          Arquitectando el panorama digital con precisión de ingeniería e intuición creativa.
        </p>
      </div>
      <div>
        <h4 class="text-on-surface font-label font-bold mb-4">Explorar</h4>
        <div class="flex flex-col space-y-2">
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="/es/services">Servicios</a>
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="/es/blog">Perspectivas</a>
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="/es/contact">Contacto</a>
        </div>
      </div>
      <div>
        <h4 class="text-on-surface font-label font-bold mb-4">Legal</h4>
        <div class="flex flex-col space-y-2">
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="#">Política de privacidad</a>
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="#">Términos de servicio</a>
        </div>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-6 py-8 border-t border-slate-800/20 text-center">
      <p class="font-body text-sm text-slate-400">© 2026 Horizon.gh. Ingeniería del Horizonte Digital.</p>
    </div>
  </footer>
</Layout>

<style>
  .blog-content :global(h2) {
    margin: 2.5rem 0 1.2rem;
    font-size: 2rem;
    font-family: var(--font-display);
    color: var(--color-on-surface);
  }

  .blog-content :global(h3) {
    margin: 2rem 0 0.8rem;
    font-size: 1.45rem;
    font-family: var(--font-display);
    color: var(--color-on-surface);
  }

  .blog-content :global(p) {
    margin: 0 0 1.3rem;
    line-height: 1.8;
    color: var(--color-on-surface-variant);
    font-size: 1rem;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin: 0 0 1.5rem 1.5rem;
    padding-left: 1rem;
    color: var(--color-on-surface-variant);
    line-height: 1.8;
  }

  .blog-content :global(li) {
    margin-bottom: 0.65rem;
  }

  .blog-content :global(a) {
    color: var(--color-accent-cyan);
    text-decoration: underline;
  }

  .blog-content :global(blockquote) {
    margin: 2rem 0;
    padding: 1.6rem 1.8rem;
    border-left: 4px solid var(--color-accent-cyan);
    background: rgba(76, 214, 251, 0.06);
    color: var(--color-on-surface);
    border-radius: 1rem;
  }

  .blog-content :global(pre) {
    margin: 1.5rem 0;
    overflow-x: auto;
    border-radius: 1rem;
    background: #0d0d0d;
    padding: 1rem;
  }

  .blog-content :global(code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.2rem 0.35rem;
    border-radius: 0.45rem;
    color: var(--color-primary);
  }
</style>
