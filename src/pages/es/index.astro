---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';

const locale = 'es';

const painPoints = [
  'Procesos manuales que no escalan',
  'Herramientas desconectadas',
  'Falta de visibilidad sobre el negocio',
  'Perdida de oportunidades'
];

const services = [
  {
    icon: 'web',
    title: 'Desarrollo Web',
    copy: 'Sitios y landing pages disenados para convertir visitas en clientes.'
  },
  {
    icon: 'code_blocks',
    title: 'Productos de Software',
    copy: 'Sistemas internos, APIs y plataformas que optimizan tu operacion.'
  },
  {
    icon: 'monitoring',
    title: 'Dashboards Operativos',
    copy: 'Visualiza en tiempo real lo que ocurre en tu negocio y toma mejores decisiones.'
  }
];

const workSteps = [
  'Analizamos tu negocio',
  'Disenamos la arquitectura digital',
  'Desarrollamos el sistema',
  'Iteramos y escalamos'
];

const samples = [
  {
    title: 'Landing SaaS',
    problem: 'Funnel de conversion debil y baja velocidad del sitio.',
    solution: 'Rediseno del funnel y optimizacion de arquitectura.',
    result: 'Mayor conversion y mejor rendimiento en campanas.'
  },
  {
    title: 'Portal de Operaciones',
    problem: 'Solicitudes, reportes y SLA gestionados en herramientas separadas.',
    solution: 'Plataforma interna unificada con flujos por roles.',
    result: 'Respuesta mas rapida y visibilidad completa del equipo.'
  },
  {
    title: 'Suite de Automatizacion',
    problem: 'Equipos dedicando horas a reportes repetitivos.',
    solution: 'Automatizacion de pipelines de datos y reportes programados.',
    result: 'Mas tiempo de ejecucion y menos errores operativos.'
  }
];

const differentiators = [
  'No usamos plantillas',
  'Disenamos sistemas, no solo interfaces',
  'Pensamos en escalabilidad desde el inicio',
  'Enfocados en resultados reales, no solo estetica'
];
---

<Layout title="Horizon.gh | Ingenieria del Horizonte Digital" locale={locale}>
  <Navigation locale={locale} />

  <main>
    <section class="relative min-h-screen overflow-hidden pt-16 sm:pt-20 md:pt-24">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/85 to-surface/30"></div>
        <img
          alt="Conectividad digital"
          class="h-full w-full object-cover"
          src="https://res.cloudinary.com/dnta7zbad/image/upload/v1776103096/heroPageImage_rfon1c.png"
        />
        <div class="absolute inset-x-0 bottom-0 h-32 sm:h-44 bg-gradient-to-t from-surface to-transparent"></div>
      </div>
      <div class="relative z-10 mx-auto flex min-h-[70vh] sm:min-h-[78vh] w-full max-w-7xl items-center px-4 sm:px-6">
        <div class="max-w-3xl space-y-6 sm:space-y-8" data-motion="fade-up">
          <h1 class="text-3xl sm:text-5xl font-display font-bold leading-[1.05] tracking-tight text-on-surface md:text-7xl lg:text-8xl">
            Ingenieria del Horizonte Digital
          </h1>
          <p class="max-w-2xl text-base sm:text-lg leading-relaxed text-on-surface-variant md:text-2xl">
            Construimos la base digital de tu negocio con software y sistemas disenados para escalar.
          </p>
          <p class="max-w-2xl text-sm sm:text-base leading-relaxed text-on-surface-variant md:text-lg">
            Webs, plataformas y herramientas internas que convierten tu operacion en un sistema eficiente.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <Button href="/es/services" size="lg">Explorar servicios</Button>
            <Button href="/es/contact" variant="outline" size="lg">Reservar llamada estrategica</Button>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 sm:px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl" data-motion="fade-up">
        <p class="text-xs font-label uppercase tracking-[0.18em] text-tertiary">El problema</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">
          La mayoria de negocios opera sin una base digital real
        </h2>
        <div class="mt-6 sm:mt-8 grid gap-4 md:grid-cols-2" data-motion-group="problem">
          {
            painPoints.map((point) => (
              <Card interactive class="micro-hover" data-card>
                <p class="text-base text-on-surface">{point}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 pb-20">
      <div class="mx-auto max-w-7xl rounded-3xl border border-primary/25 bg-primary/10 p-8 md:p-12" data-motion="fade-up">
        <p class="text-xs font-label uppercase tracking-[0.18em] text-primary">Solucion</p>
        <p class="mt-3 text-2xl font-display font-bold leading-relaxed text-on-surface md:text-3xl">
          En Horizon.gh disenamos sistemas digitales que organizan, automatizan y preparan tu negocio para crecer.
        </p>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12" data-motion="fade-up">
          <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Servicios orientados a valor real</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-3" data-motion-group="services">
          {
            services.map((service) => (
              <Card interactive class="micro-hover" data-card>
                <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-primary/35 bg-primary/10 text-primary">
                  <span class="material-symbols-outlined">{service.icon}</span>
                </div>
                <h3 class="text-2xl font-display font-bold text-on-surface">{service.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">{service.copy}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl" data-motion="fade-up">
        <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Como trabajamos</h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4" data-motion-group="process">
          {
            workSteps.map((step, index) => (
              <Card interactive class="micro-hover" data-card>
                <p class="text-xs font-label uppercase tracking-[0.18em] text-primary">Paso {index + 1}</p>
                <p class="mt-3 text-base text-on-surface">{step}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl rounded-[2rem] border border-outline-variant/30 bg-surface-container-low p-7 md:p-11">
        <div class="mb-8" data-motion="fade-up">
          <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Sistemas reales, no conceptos</h2>
        </div>
        <div class="grid gap-5 lg:grid-cols-3" data-motion-group="samples">
          {
            samples.map((item) => (
              <article class="micro-hover rounded-3xl border border-outline-variant/30 bg-[#111827] p-5" data-card>
                <h3 class="text-xl font-display font-bold text-on-surface">{item.title}</h3>
                <p class="mt-4 text-sm text-on-surface"><span class="font-semibold text-primary">Problema:</span> {item.problem}</p>
                <p class="mt-2 text-sm text-on-surface"><span class="font-semibold text-primary">Solucion:</span> {item.solution}</p>
                <p class="mt-2 text-sm text-on-surface"><span class="font-semibold text-primary">Resultado:</span> {item.result}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl" data-motion="fade-up">
        <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Por que Horizon.gh</h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2" data-motion-group="why">
          {
            differentiators.map((item) => (
              <Card interactive class="micro-hover" data-card>
                <p class="text-base text-on-surface">{item}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 pb-24 pt-14">
      <div class="mx-auto max-w-7xl rounded-3xl border border-outline-variant/35 bg-surface-container p-10 text-center md:p-14" data-motion="fade-up">
        <h2 class="text-3xl font-display font-bold text-on-surface md:text-5xl">Tu negocio necesita mas que presencia digital. Necesita un sistema.</h2>
        <div class="mt-8">
          <Button href="/es/contact" size="lg">Reservar llamada estrategica</Button>
        </div>
      </div>
    </section>
  </main>

  <script type="module">
    import { animate, inView, stagger } from '@motionone/dom';

    const animateEnter = (target, y = 18) => {
      animate(
        target,
        { opacity: [0, 1], transform: [`translateY(${y}px)`, 'translateY(0px)'] },
        { duration: 0.65, easing: [0.22, 1, 0.36, 1] }
      );
    };

    document.querySelectorAll('[data-motion="fade-up"]').forEach((el) => {
      inView(el, () => animateEnter(el));
    });

    document.querySelectorAll('[data-motion-group]').forEach((group) => {
      const cards = group.querySelectorAll('[data-card]');
      inView(group, () => {
        animate(
          cards,
          { opacity: [0, 1], transform: ['translateY(18px)', 'translateY(0px)'] },
          { duration: 0.55, delay: stagger(0.08), easing: [0.22, 1, 0.36, 1] }
        );
      });
    });
  </script>
</Layout>
