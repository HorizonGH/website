---
const t = useTranslations('es') as any;

import { useTranslations } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
---

<Layout locale="es" title={t.seo.home_title}>
  <!-- Add Cursive Font for the signatures -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap" rel="stylesheet">

  <div class="min-h-screen bg-white text-black font-sans relative overflow-hidden">
    <!-- Abstract Circuit Background in Hero -->
    <div class="absolute inset-0 pointer-events-none opacity-5 z-0" 
         style="background-image: radial-gradient(#00E5FF 1px, transparent 1px), radial-gradient(#00E5FF 1px, transparent 1px); background-size: 40px 40px; background-position: 0 0, 20px 20px;">
    </div>

    <!-- Hero Section -->
    <section class="relative z-10 container mx-auto px-6 pt-40 pb-32 md:pt-52 md:pb-40 text-center">
      <h1 class="text-3xl sm:text-5xl md:text-7xl lg:text-8xl leading-tight font-black tracking-tighter mb-6 break-words">
        TRANSFORMANDO EL <br />
        <span class="whitespace-nowrap">H<span class="inline-block relative w-[0.8em] h-[1em] mx-1 align-middle text-[#00E5FF]">
          <!-- Circuit 'O' -->
          <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full fill-none stroke-current" stroke-width="8" preserveAspectRatio="xMidYMid meet">
            <circle cx="50" cy="50" r="40" stroke-dasharray="25 10 15 10" />
            <circle cx="50" cy="50" r="25" />
            <circle cx="50" cy="10" r="5" class="fill-current" />
            <circle cx="90" cy="50" r="5" class="fill-current" />
            <circle cx="50" cy="90" r="5" class="fill-current" />
            <circle cx="10" cy="50" r="5" class="fill-current" />
          </svg>
        </span>RIZONTE</span> <br class="sm:hidden" /><span class="whitespace-nowrap">D<span class="inline-block relative w-[0.6em] h-[1em] mx-1 align-middle text-[#00E5FF]">
          <!-- Circuit 'I' -->
          <svg viewBox="0 0 24 100" class="absolute inset-0 w-full h-full fill-current" preserveAspectRatio="xMidYMid meet">
            <rect x="10" y="10" width="4" height="80" />
            <circle cx="12" cy="10" r="6" />
            <circle cx="12" cy="90" r="6" />
            <circle cx="12" cy="50" r="4" class="text-white fill-current" />
          </svg>
        </span>GITAL.</span>
      </h1>
      <p class="text-lg leading-relaxed sm:text-xl sm:leading-relaxed md:text-2xl text-gray-600 mb-10 max-w-3xl mx-auto font-light">
        {t.home_page.hero_subtitle}
      </p>
      <div class="flex justify-center px-4 sm:px-0">
        <a href="#contact" class="group flex items-center justify-center w-full sm:w-auto bg-[#00E5FF] text-black font-bold text-lg py-3 px-6 sm:py-4 sm:px-8 rounded-full transition-all duration-300 hover:shadow-[0_0_20px_rgba(0,229,255,0.6)] hover:-translate-y-1">
          {t.hero.cta}
          <svg class="w-6 h-6 ml-3 group-hover:rotate-45 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </a>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="bg-gray-50 py-24 relative border-t border-gray-100">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold mb-4">{t.services.title}</h2>
          <div class="w-24 h-1 bg-[#00E5FF] mx-auto"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Service Card 1 -->
          <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-[0_0_20px_rgba(0,229,255,0.3)] transition-all duration-300 border border-transparent hover:border-[#00E5FF]/30 group">
            <div class="w-14 h-14 bg-[#00E5FF]/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#00E5FF] transition-colors">
              <svg class="w-8 h-8 text-[#00E5FF] group-hover:text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{t.services.card1_title}</h3>
            <p class="text-gray-600">{t.home_page.services_card1_desc}</p>
          </div>
          <!-- Service Card 2 -->
          <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-[0_0_20px_rgba(0,229,255,0.3)] transition-all duration-300 border border-transparent hover:border-[#00E5FF]/30 group">
            <div class="w-14 h-14 bg-[#00E5FF]/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#00E5FF] transition-colors">
              <svg class="w-8 h-8 text-[#00E5FF] group-hover:text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{t.services.card2_title}</h3>
            <p class="text-gray-600">{t.home_page.services_card2_desc}</p>
          </div>
          <!-- Service Card 3 -->
          <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-[0_0_20px_rgba(0,229,255,0.3)] transition-all duration-300 border border-transparent hover:border-[#00E5FF]/30 group">
            <div class="w-14 h-14 bg-[#00E5FF]/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#00E5FF] transition-colors">
              <svg class="w-8 h-8 text-[#00E5FF] group-hover:text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">{t.services.card3_title}</h3>
            <p class="text-gray-600">{t.home_page.services_card3_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process: Deconstructed 'H' Section -->
    <section class="py-24 bg-white relative">
      <div class="container mx-auto px-6">
        <h2 class="text-4xl font-bold mb-16 text-center text-black">{t.framework.title}</h2>
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-center gap-8 md:gap-8 relative">
          <!-- Background connection lines for desktop -->
          <div class="hidden md:block absolute top-1/2 left-0 right-0 h-2 bg-gray-100 -z-10 -translate-y-1/2"></div>
          <!-- Background connection line for mobile -->
          <div class="md:hidden absolute top-0 bottom-0 left-1/2 w-1 bg-gray-100 -z-10 -translate-x-1/2"></div>
          
          <!-- H Left Vertical -->
          <div class="flex-1 text-center bg-gray-50 p-8 rounded-lg shadow-sm w-full md:transform md:-translate-y-8 border-l-4 border-[#00E5FF]">
            <div class="text-[#00E5FF] font-black text-6xl mb-4">01</div>
            <h4 class="text-xl font-bold mb-2">{t.framework.step1_title}</h4>
            <p class="text-gray-600 text-sm">{t.home_page.framework_step1_desc}</p>
          </div>
          
          <!-- H Horizontal Crossbar -->
          <div class="flex-1 text-center bg-[#00E5FF] text-black p-8 rounded-lg shadow-lg w-full md:scale-110 z-10 transition-transform hover:scale-115">
            <div class="font-black text-6xl mb-4 opacity-70">02</div>
            <h4 class="text-xl font-bold mb-2">{t.framework.step2_title}</h4>
            <p class="text-gray-800 text-sm font-medium">{t.home_page.framework_step2_desc}</p>
          </div>
          
          <!-- H Right Vertical -->
          <div class="flex-1 text-center bg-gray-50 p-8 rounded-lg shadow-sm w-full md:transform md:translate-y-8 border-r-4 border-[#00E5FF]">
            <div class="text-[#00E5FF] font-black text-6xl mb-4">03</div>
            <h4 class="text-xl font-bold mb-2">{t.framework.step3_title}</h4>
            <p class="text-gray-600 text-sm">{t.home_page.framework_step3_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Portfolio Section -->
    <section id="portfolio" class="py-24 bg-gray-50 border-t border-gray-100">
      <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-6 md:gap-0">
          <div>
            <h2 class="text-4xl font-bold mb-4">{t.portfolio.title}</h2>
            <div class="w-24 h-1 bg-[#00E5FF]"></div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Featured Project -->
          <div class="group relative md:col-span-2 lg:col-span-2 rounded-2xl overflow-hidden bg-gray-900 border border-gray-200 hover:shadow-[0_0_20px_rgba(0,229,255,0.5)] transition-all duration-500 cursor-pointer min-h-[400px] flex flex-col justify-end p-8" style="background-image: url('https://res.cloudinary.com/dnta7zbad/image/upload/v1776224242/Screenshot_2026-04-14_233400_seerb7.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent z-10"></div>
            <!-- Horizon Logo overlay pattern -->
            <div class="absolute inset-0 opacity-10 flex items-center justify-center">
              <span class="text-9xl font-black text-white">HxG</span>
            </div>
            <div class="relative z-20 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-[#00E5FF] text-sm font-bold tracking-wider uppercase mb-2 block">{t.home_page.featured_project_category}</span>
              <h3 class="text-3xl text-white font-bold mb-2">{t.home_page.featured_project_title}</h3>
              <p class="text-gray-300 text-sm max-w-lg mb-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-100">{t.home_page.featured_project_desc}</p>
            </div>
          </div>

          <!-- Project 2 -->
          <div class="group relative rounded-2xl overflow-hidden bg-white border border-gray-200 hover:border-[#00E5FF] hover:shadow-[0_0_20px_rgba(0,229,255,0.5)] transition-all duration-500 cursor-pointer min-h-[400px] flex flex-col justify-end p-8" style="background-image: url('https://res.cloudinary.com/dnta7zbad/image/upload/v1776224241/Screenshot_2026-04-14_233700_yorgxn.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900/90 to-transparent z-10"></div>
            <div class="relative z-20 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-[#00E5FF] text-sm font-bold tracking-wider uppercase mb-2 block">{t.portfolio.proj2_cat}</span>
              <h3 class="text-2xl text-white font-bold mb-2">{t.home_page.project2_title}</h3>
            </div>
          </div>

          <!-- Project 3 -->
          <div class="group relative rounded-2xl overflow-hidden bg-white border border-gray-200 hover:border-[#00E5FF] hover:shadow-[0_0_20px_rgba(0,229,255,0.5)] transition-all duration-500 cursor-pointer min-h-[300px] flex flex-col justify-end p-8" style="background-image: url('https://res.cloudinary.com/dnta7zbad/image/upload/v1776224245/Screenshot_2026-04-14_233508_motvm1.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
             <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900/90 to-transparent z-10"></div>
            <div class="relative z-20 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-[#00E5FF] text-sm font-bold tracking-wider uppercase mb-2 block">{t.home_page.project3_category}</span>
              <h3 class="text-2xl text-white font-bold mb-2">{t.home_page.project3_title}</h3>
            </div>
          </div>

          <!-- Project 4 -->
          <div class="group relative md:col-span-2 rounded-2xl overflow-hidden bg-white border border-gray-200 hover:border-[#00E5FF] hover:shadow-[0_0_20px_rgba(0,229,255,0.5)] transition-all duration-500 cursor-pointer min-h-[300px] flex flex-col justify-end p-8" style="background-image: url('https://res.cloudinary.com/dnta7zbad/image/upload/v1776224244/Screenshot_2026-04-14_233436_dyhlu8.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-gray-900/90 to-transparent z-10"></div>
            <div class="relative z-20 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
              <span class="text-[#00E5FF] text-sm font-bold tracking-wider uppercase mb-2 block">{t.home_page.project4_category}</span>
              <h3 class="text-3xl text-white font-bold mb-2">{t.home_page.project4_title}</h3>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <section class="py-24 bg-white">
      <div class="container mx-auto px-6">
        <h2 class="text-4xl font-bold mb-16 text-center text-black">{t.testimonials.title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Testimonial 1 -->
          <div class="bg-gray-900 rounded-2xl p-8 text-white relative flex flex-col shadow-xl">
            <svg class="w-8 h-8 text-[#00E5FF] mb-6 opacity-80" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
            <p class="text-gray-300 italic mb-8 flex-grow">"{t.home_page.testimonial1_quote}"</p>
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-700 rounded-full mr-4 flex items-center justify-center overflow-hidden border-2 border-[#00E5FF]">
                <img src="https://ui-avatars.com/api/?name=Jhon+M&background=00E5FF&color=000" alt="Jhon S" class="w-full h-full object-cover"/>
              </div>
              <div>
                <h4 class="font-bold text-white">{t.testimonials.t1_name}</h4>
                <span class="text-sm text-gray-400">{t.testimonials.t1_role}</span>
              </div>
            </div>
            <div class="absolute bottom-6 right-8 opacity-40 transform rotate-[-10deg]">
               <span class="text-[#00E5FF] font-['Caveat'] text-2xl">-gh</span>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="bg-gray-900 rounded-2xl p-8 text-white relative flex flex-col shadow-xl">
            <svg class="w-8 h-8 text-[#00E5FF] mb-6 opacity-80" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
            <p class="text-gray-300 italic mb-8 flex-grow">"{t.home_page.testimonial2_quote}"</p>
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-700 rounded-full mr-4 flex items-center justify-center overflow-hidden border-2 border-[#00E5FF]">
                 <img src="https://ui-avatars.com/api/?name=Sarah+A&background=00E5FF&color=000" alt="Sarah A" class="w-full h-full object-cover"/>
              </div>
              <div>
                <h4 class="font-bold text-white">{t.testimonials.t2_name}</h4>
                <span class="text-sm text-gray-400">{t.home_page.testimonial2_role}</span>
              </div>
            </div>
            <div class="absolute bottom-6 right-8 opacity-40 transform rotate-[-10deg]">
               <span class="text-[#00E5FF] font-['Caveat'] text-2xl">-gh</span>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div class="bg-gray-900 rounded-2xl p-8 text-white relative flex flex-col shadow-xl">
            <svg class="w-8 h-8 text-[#00E5FF] mb-6 opacity-80" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
            <p class="text-gray-300 italic mb-8 flex-grow">"{t.home_page.testimonial3_quote}"</p>
            <div class="flex items-center">
              <div class="w-12 h-12 bg-gray-700 rounded-full mr-4 flex items-center justify-center overflow-hidden border-2 border-[#00E5FF]">
                 <img src="https://ui-avatars.com/api/?name=David+O&background=00E5FF&color=000" alt="David O" class="w-full h-full object-cover"/>
              </div>
              <div>
                <h4 class="font-bold text-white">{t.testimonials.t3_name}</h4>
                <span class="text-sm text-gray-400">{t.home_page.testimonial3_role}</span>
              </div>
            </div>
             <div class="absolute bottom-6 right-8 opacity-40 transform rotate-[-10deg]">
               <span class="text-[#00E5FF] font-['Caveat'] text-2xl">-gh</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer & Contact -->
    <footer id="contact" class="bg-black text-white py-20 border-t-4 border-[#00E5FF]">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
          
          <!-- Contact Form -->
          <div>
            <h2 class="text-3xl font-bold mb-8">{t.contact.title}</h2>
            <form class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-400 mb-2">{t.home_page.form_name}</label>
                <input type="text" id="name" class="w-full bg-gray-900 border border-gray-800 text-white px-4 py-3 rounded-lg focus:outline-none focus:border-[#00E5FF] transition-colors" placeholder={t.home_page.form_name_placeholder}>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-400 mb-2">{t.home_page.form_email}</label>
                <input type="email" id="email" class="w-full bg-gray-900 border border-gray-800 text-white px-4 py-3 rounded-lg focus:outline-none focus:border-[#00E5FF] transition-colors" placeholder={t.home_page.form_email_placeholder}>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-400 mb-2">{t.home_page.form_message}</label>
                <textarea id="message" rows="4" class="w-full bg-gray-900 border border-gray-800 text-white px-4 py-3 rounded-lg focus:outline-none focus:border-[#00E5FF] transition-colors" placeholder={t.home_page.form_message_placeholder}></textarea>
              </div>
              <button type="submit" class="bg-[#00E5FF] text-black font-bold py-3 px-8 rounded-lg hover:bg-cyan-400 transition-colors w-full md:w-auto">
                {t.contact.submit}
              </button>
            </form>
          </div>

          <!-- Footer Information -->
          <div class="flex flex-col justify-between">
            <div>
              <div class="text-3xl font-bold mb-6">
                Horizon <span class="text-[#00E5FF] font-['Caveat'] text-4xl ml-1">-gh</span>
              </div>
              <p class="text-gray-400 mb-8 max-w-sm">
                {t.home_page.footer_description}
              </p>
              
              <div class="space-y-4 text-sm text-gray-400">
                <p class="flex items-center">
                  <svg class="w-5 h-5 mr-3 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  America
                </p>
                <p class="flex items-center">
                  <svg class="w-5 h-5 mr-3 text-[#00E5FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                  hello@horizon.gh
                </p>
              </div>
            </div>

            <div class="mt-12 md:mt-0 flex flex-col md:flex-row justify-between items-start md:items-end">
              <!-- Social Links -->
              <div class="flex space-x-4 mb-6 md:mb-0">
                <a href="#" class="text-gray-400 hover:text-[#00E5FF] transition-colors p-2 bg-gray-900 rounded-full">
                  <span class="sr-only">{t.home_page.social_x}</span>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                </a>
                <a href="#" class="text-gray-400 hover:text-[#00E5FF] transition-colors p-2 bg-gray-900 rounded-full">
