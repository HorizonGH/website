---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';

const locale = 'en';

const painPoints = [
  'Manual processes that do not scale',
  'Disconnected tools and fragmented workflows',
  'Low visibility into business performance',
  'Missed revenue opportunities'
];

const services = [
  {
    icon: 'web',
    title: 'Web Development',
    copy: 'Websites and landing pages designed to convert visits into customers.'
  },
  {
    icon: 'code_blocks',
    title: 'Software Products',
    copy: 'Internal systems, APIs, and platforms that optimize your operations.'
  },
  {
    icon: 'monitoring',
    title: 'Operational Dashboards',
    copy: 'See what is happening in real time and make better business decisions.'
  }
];

const workSteps = [
  'We analyze your business',
  'We design the digital architecture',
  'We build the system',
  'We iterate and scale'
];

const samples = [
  {
    title: 'SaaS Landing',
    problem: 'Low conversion funnel and poor page speed.',
    solution: 'Funnel redesign and page architecture optimization.',
    result: 'Higher lead conversion and better campaign performance.'
  },
  {
    title: 'Operations Portal',
    problem: 'Requests, reports, and SLAs were tracked in multiple tools.',
    solution: 'Unified internal platform with role-based workflows.',
    result: 'Faster response times and full team visibility.'
  },
  {
    title: 'Automation Suite',
    problem: 'Teams were spending hours on repetitive reporting.',
    solution: 'Automated data pipelines and scheduled reporting.',
    result: 'More execution time and fewer operational errors.'
  }
];

const differentiators = [
  'We do not use generic templates',
  'We design systems, not only interfaces',
  'We think about scalability from day one',
  'We focus on real outcomes, not only aesthetics'
];
---

<Layout title="Horizon.gh | Engineering the Digital Horizon" locale={locale}>
  <Navigation locale={locale} />

  <main>
    <section class="relative min-h-screen overflow-hidden pt-24">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/85 to-surface/30"></div>
        <img
          alt="Digital connectivity"
          class="h-full w-full object-cover"
          src="https://res.cloudinary.com/dnta7zbad/image/upload/v1776103096/heroPageImage_rfon1c.png"
        />
        <div class="absolute inset-x-0 bottom-0 h-44 bg-gradient-to-t from-surface to-transparent"></div>
      </div>
      <div class="relative z-10 mx-auto flex min-h-[78vh] w-full max-w-7xl items-center px-6">
        <div class="max-w-3xl space-y-8" data-motion="fade-up">
          <h1 class="text-5xl font-display font-bold leading-[1.05] tracking-tight text-on-surface md:text-7xl lg:text-8xl">
            Engineering the Digital Horizon
          </h1>
          <p class="max-w-2xl text-lg leading-relaxed text-on-surface-variant md:text-2xl">
            We build the digital foundation of your business with software and systems designed to scale.
          </p>
          <p class="max-w-2xl text-base leading-relaxed text-on-surface-variant md:text-lg">
            Websites, platforms, and internal tools that turn your operation into an efficient system.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <Button href="/services" size="lg">Explore services</Button>
            <Button href="/contact" variant="outline" size="lg">Book strategic call</Button>
          </div>
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl" data-motion="fade-up">
        <p class="text-xs font-label uppercase tracking-[0.18em] text-tertiary">The problem</p>
        <h2 class="mt-3 text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">
          Most businesses operate without a real digital foundation
        </h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2" data-motion-group="problem">
          {
            painPoints.map((point) => (
              <Card interactive class="micro-hover" data-card>
                <p class="text-base text-on-surface">{point}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 pb-20">
      <div class="mx-auto max-w-7xl rounded-3xl border border-primary/25 bg-primary/10 p-8 md:p-12" data-motion="fade-up">
        <p class="text-xs font-label uppercase tracking-[0.18em] text-primary">Solution</p>
        <p class="mt-3 text-2xl font-display font-bold leading-relaxed text-on-surface md:text-3xl">
          At Horizon.gh we design digital systems that organize, automate, and prepare your business for growth.
        </p>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12" data-motion="fade-up">
          <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Services built for business value</h2>
        </div>
        <div class="grid gap-5 md:grid-cols-3" data-motion-group="services">
          {
            services.map((service) => (
              <Card interactive class="micro-hover" data-card>
                <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-primary/35 bg-primary/10 text-primary">
                  <span class="material-symbols-outlined">{service.icon}</span>
                </div>
                <h3 class="text-2xl font-display font-bold text-on-surface">{service.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">{service.copy}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl" data-motion="fade-up">
        <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">How we work</h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4" data-motion-group="process">
          {
            workSteps.map((step, index) => (
              <Card interactive class="micro-hover" data-card>
                <p class="text-xs font-label uppercase tracking-[0.18em] text-primary">Step {index + 1}</p>
                <p class="mt-3 text-base text-on-surface">{step}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl rounded-[2rem] border border-outline-variant/30 bg-surface-container-low p-7 md:p-11">
        <div class="mb-8" data-motion="fade-up">
          <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Real systems, not concepts</h2>
        </div>
        <div class="grid gap-5 lg:grid-cols-3" data-motion-group="samples">
          {
            samples.map((item) => (
              <article class="micro-hover rounded-3xl border border-outline-variant/30 bg-[#111827] p-5" data-card>
                <h3 class="text-xl font-display font-bold text-on-surface">{item.title}</h3>
                <p class="mt-4 text-sm text-on-surface"><span class="font-semibold text-primary">Problem:</span> {item.problem}</p>
                <p class="mt-2 text-sm text-on-surface"><span class="font-semibold text-primary">Solution:</span> {item.solution}</p>
                <p class="mt-2 text-sm text-on-surface"><span class="font-semibold text-primary">Result:</span> {item.result}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 py-20">
      <div class="mx-auto max-w-7xl" data-motion="fade-up">
        <h2 class="text-4xl font-display font-bold tracking-tight text-on-surface md:text-5xl">Why Horizon.gh</h2>
        <div class="mt-8 grid gap-4 md:grid-cols-2" data-motion-group="why">
          {
            differentiators.map((item) => (
              <Card interactive class="micro-hover" data-card>
                <p class="text-base text-on-surface">{item}</p>
              </Card>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 pb-24 pt-14">
      <div class="mx-auto max-w-7xl rounded-3xl border border-outline-variant/35 bg-surface-container p-10 text-center md:p-14" data-motion="fade-up">
        <h2 class="text-3xl font-display font-bold text-on-surface md:text-5xl">Your business needs more than digital presence. It needs a system.</h2>
        <div class="mt-8">
          <Button href="/contact" size="lg">Book strategic call</Button>
        </div>
      </div>
    </section>
  </main>

  <script type="module">
    import { animate, inView, stagger } from '@motionone/dom';

    const animateEnter = (target, y = 18) => {
      animate(
        target,
        { opacity: [0, 1], transform: [`translateY(${y}px)`, 'translateY(0px)'] },
        { duration: 0.65, easing: [0.22, 1, 0.36, 1] }
      );
    };

    document.querySelectorAll('[data-motion="fade-up"]').forEach((el) => {
      inView(el, () => animateEnter(el));
    });

    document.querySelectorAll('[data-motion-group]').forEach((group) => {
      const cards = group.querySelectorAll('[data-card]');
      inView(group, () => {
        animate(
          cards,
          { opacity: [0, 1], transform: ['translateY(18px)', 'translateY(0px)'] },
          { duration: 0.55, delay: stagger(0.08), easing: [0.22, 1, 0.36, 1] }
        );
      });
    });
  </script>
</Layout>
