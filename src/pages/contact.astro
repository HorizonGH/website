---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { useTranslations } from '../i18n/utils';

const locale = 'en';
const t = useTranslations(locale);
---

<Layout title="Contact | Horizon.gh" locale={locale}>
  <Navigation locale={locale} />

  <main class="pt-32 pb-24 px-6 overflow-hidden">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto mb-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end">
        <div>
          <h1 class="font-display text-6xl md:text-8xl font-bold tracking-tighter text-on-surface mb-6 leading-[0.9]">
            Get in <span class="text-primary italic">Touch</span>
          </h1>
          <p class="font-body text-xl text-on-surface-variant max-w-lg leading-relaxed">
            Let us discuss how we can accelerate your business with technology. Our team of engineers is ready to architect your next digital leap.
          </p>
        </div>
        <div class="hidden lg:block relative">
          <div class="absolute -top-24 -right-12 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
          <div class="w-full h-1 bg-gradient-to-r from-primary to-transparent opacity-30"></div>
        </div>
      </div>
    </section>

    <!-- Main Grid -->
    <section class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Contact Form Section -->
        <div class="lg:col-span-7 bg-surface-container-low rounded-xl p-8 md:p-12 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full -mr-16 -mt-16 transition-transform group-hover:scale-150 duration-700"></div>
          <form action="#" class="relative z-10 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="font-label text-xs uppercase tracking-widest text-slate-500 ml-1">{t.contact.form.name}</label>
                <input
                  class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all duration-300 placeholder:text-slate-600"
                  placeholder="John Doe"
                  type="text"
                />
              </div>
              <div class="space-y-2">
                <label class="font-label text-xs uppercase tracking-widest text-slate-500 ml-1">{t.contact.form.email}</label>
                <input
                  class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all duration-300 placeholder:text-slate-600"
                  placeholder="john@company.com"
                  type="email"
                />
              </div>
            </div>
            <div class="space-y-2">
                <label class="font-label text-xs uppercase tracking-widest text-slate-500 ml-1">Company</label>
              <input
                class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all duration-300 placeholder:text-slate-600"
                placeholder="Project Inquiry"
                type="text"
              />
            </div>
            <div class="space-y-2">
                <label class="font-label text-xs uppercase tracking-widest text-slate-500 ml-1">{t.contact.form.message}</label>
              <textarea
                class="w-full bg-surface-container-highest border-none rounded-lg p-4 text-on-surface focus:ring-2 focus:ring-primary transition-all duration-300 placeholder:text-slate-600 resize-none"
                placeholder="Tell us about your vision..."
                rows="6"
              ></textarea>
            </div>
            <button
              class="w-full md:w-auto cta-gradient text-on-primary font-bold px-10 py-4 rounded-lg hover:opacity-90 transition-all duration-300 flex items-center justify-center gap-2 group"
              type="submit"
            >
              Send Message
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">send</span>
            </button>
          </form>
        </div>

        <!-- Info & Sidebar Section -->
        <div class="lg:col-span-5 space-y-8">
          <div class="bg-surface-container-high rounded-xl p-8 border-l-4 border-primary">
            <h3 class="font-display text-2xl font-bold text-on-surface mb-6">HQ Operations</h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">location_on</span>
                <div>
                  <p class="font-label text-sm text-slate-500">Silicon Roundabout</p>
                  <p class="text-on-surface">12-14 Old Street, London<br />EC1V 9AB, United Kingdom</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">alternate_email</span>
                <div>
                  <p class="font-label text-sm text-slate-500">Electronic Mail</p>
                  <p class="text-on-surface">hello@horizon.gh</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <span class="material-symbols-outlined text-primary p-2 bg-primary/10 rounded-lg">call</span>
                <div>
                  <p class="font-label text-sm text-slate-500">Direct Line</p>
                  <p class="text-on-surface">+44 (0) 20 7946 0123</p>
                </div>
              </div>
            </div>

            <div class="mt-8 pt-8 border-t border-slate-700/30 flex gap-4">
              <a class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center text-slate-400 hover:text-primary hover:scale-110 transition-all duration-300" href="#">
                <span class="material-symbols-outlined text-lg">share</span>
              </a>
              <a class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center text-slate-400 hover:text-primary hover:scale-110 transition-all duration-300" href="#">
                <span class="material-symbols-outlined text-lg">public</span>
              </a>
            </div>
          </div>

          <div class="h-64 bg-surface-container-low rounded-xl relative overflow-hidden group grayscale hover:grayscale-0 transition-all duration-700">
            <img
              class="w-full h-full object-cover opacity-60 group-hover:scale-110 transition-transform duration-[2000ms]"
              alt="Stylized city map"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCxIwUfZViizse6lY9cdT7PWHAd5JKw9oTSuvuKT9VIHQZ5ipXj4gMFV7431OlCBjLr3-ggHhBfilKBBLUD9yyHuGYa8FsNJpoDr8sM2RZWGTajweotAMsxe1Rv74rCarWTpmKwD2XT2bx9NcpP7gOGUV7bP9XzvjX4Ju-KAzqaZPNz4ch3K_hnLJSL032NzdorxOQqar-qTcK6epYuyIrVynUcEHLQ3rrpRmaKKQCdq8fUb8WSbJ0x6XEXD2M9mTOjJHoFVzxq_B4"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent opacity-60"></div>
            <div class="absolute bottom-6 left-6 flex items-center gap-2 bg-primary/20 backdrop-blur-md px-3 py-1 rounded-full border border-primary/30">
              <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
              <span class="text-xs font-label font-bold text-primary tracking-widest uppercase">Live Status: Online</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="max-w-7xl mx-auto mt-24">
      <div class="text-center mb-16">
        <h2 class="font-display text-4xl font-bold mb-4">Common <span class="text-tertiary">Inquiries</span></h2>
        <div class="w-24 h-1 bg-primary mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-surface-container p-6 rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
          <h4 class="font-display font-bold text-lg text-primary mb-2">What is the typical project timeline?</h4>
          <p class="text-slate-400 leading-relaxed">
            Most MVP developments take 8-12 weeks, while larger enterprise transformations are phased over 6+ months to ensure stability.
          </p>
        </div>
        <div class="bg-surface-container p-6 rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
          <h4 class="font-display font-bold text-lg text-primary mb-2">Do you offer post-launch support?</h4>
          <p class="text-slate-400 leading-relaxed">
            Absolutely. We offer 24/7 maintenance retainers and active monitoring to ensure your infrastructure scales alongside your growth.
          </p>
        </div>
        <div class="bg-surface-container p-6 rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
          <h4 class="font-display font-bold text-lg text-primary mb-2">Can you work with our existing stack?</h4>
          <p class="text-slate-400 leading-relaxed">
            Our engineers are tech-agnostic specialists. We audit your current environment and architect solutions that integrate seamlessly.
          </p>
        </div>
        <div class="bg-surface-container p-6 rounded-xl border border-outline-variant/10 hover:bg-surface-container-high transition-colors">
          <h4 class="font-display font-bold text-lg text-primary mb-2">How do you handle data security?</h4>
          <p class="text-slate-400 leading-relaxed">
            Security is our baseline, not an add-on. Every line of code follows OWASP standards and undergoes rigorous automated testing.
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="w-full border-t border-slate-800/30 bg-surface">
    <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-1">
        <div class="inline-flex flex-col items-start w-fit hover:opacity-90 transition-opacity mb-4">
          <div class="flex items-baseline">
            <span class="text-xl font-display font-black text-on-surface tracking-wide">Horizon</span>
            <span class="text-accent-cyan text-xl ml-[2px] leading-none" style="font-family: 'Caveat', 'Brush Script MT', cursive; font-weight: 600; transform: translateY(1px) rotate(-2deg); margin-left: 2px;">gh</span>
          </div>
          <div class="h-0.5 bg-on-surface w-[78%] mt-[1px] rounded-r-sm"></div>
        </div>
        <p class="font-body text-sm text-slate-400 leading-relaxed">Engineering the digital frontier for businesses ready to evolve.</p>
      </div>
      <div class="space-y-4">
        <h5 class="font-label text-xs uppercase tracking-widest text-primary font-bold">Solutions</h5>
        <ul class="space-y-2">
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="#">Cloud Migration</a></li>
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="#">AI Architecture</a></li>
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="#">DevOps Lifecycle</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <h5 class="font-label text-xs uppercase tracking-widest text-primary font-bold">Company</h5>
        <ul class="space-y-2">
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="#">About Us</a></li>
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="/blog">Insights</a></li>
          <li><a class="text-primary text-sm" href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <h5 class="font-label text-xs uppercase tracking-widest text-primary font-bold">Legal</h5>
        <ul class="space-y-2">
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="#">Privacy Policy</a></li>
          <li><a class="text-sm text-slate-400 hover:text-tertiary transition-colors" href="#">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-6 py-6 border-t border-slate-800/20 text-center md:text-left">
      <p class="font-body text-xs text-slate-500">© 2026 Horizon.gh. Engineering the Digital Horizon.</p>
    </div>
  </footer>
</Layout>
