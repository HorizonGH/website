---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services | Horizon.gh - Transforming the Digital Horizon">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&display=swap" rel="stylesheet">

  <div class="min-h-screen bg-white text-black font-sans relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-5 z-0" 
         style="background-image: radial-gradient(#00E5FF 1px, transparent 1px), radial-gradient(#00E5FF 1px, transparent 1px); background-size: 40px 40px; background-position: 0 0, 20px 20px;">
    </div>

    <!-- Services Hero -->
    <section class="relative z-10 container mx-auto px-6 pt-24 pb-12 text-center">
      <div class="inline-block mb-4 px-4 py-1 border-2 border-[#00E5FF] rounded-full text-sm font-bold tracking-widest uppercase">Our Ecosystem</div>
      <h1 class="text-5xl md:text-7xl font-black tracking-tighter leading-tight mb-6">
        ARCHITECTING THE <br />
        <span class="text-[#00E5FF]">FUTURE</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto font-light">
        We build robust, scalable infrastructures that accelerate your digital transformation.
      </p>
    </section>

    <!-- Core Solutions -->
    <section class="py-24 relative">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Web Development -->
          <div class="bg-gray-50 border border-gray-100 p-12 rounded-2xl hover:border-[#00E5FF] hover:shadow-[0_0_30px_rgba(0,229,255,0.2)] transition-all duration-500 group">
            <div class="w-16 h-16 bg-white border-2 border-gray-200 rounded-xl flex items-center justify-center mb-8 group-hover:border-[#00E5FF] transition-colors">
              <svg class="w-8 h-8 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <h3 class="text-4xl font-black tracking-tighter mb-4">Web <span class="text-[#00E5FF] font-['Caveat'] text-5xl">Dev</span></h3>
            <p class="text-gray-600 text-lg mb-8">
              High-performance web applications, corporate websites, and landing pages optimized for immense traffic and conversion.
            </p>
            <ul class="space-y-4 mb-8">
              <li class="flex items-center text-gray-800 font-medium"><span class="text-[#00E5FF] mr-3">&#10003;</span> Highly responsive frontend</li>
              <li class="flex items-center text-gray-800 font-medium"><span class="text-[#00E5FF] mr-3">&#10003;</span> Scalable CMS integrations</li>
              <li class="flex items-center text-gray-800 font-medium"><span class="text-[#00E5FF] mr-3">&#10003;</span> Core Web Vitals optimized</li>
            </ul>
            <a href="/contact" class="inline-flex items-center font-bold pb-1 border-b-2 border-black hover:border-[#00E5FF] hover:text-[#00E5FF] transition-colors">
              Start Building &rarr;
            </a>
          </div>

          <!-- Software Development -->
          <div class="bg-gray-900 border border-gray-800 p-12 rounded-2xl text-white hover:border-[#00E5FF] hover:shadow-[0_0_30px_rgba(0,229,255,0.4)] transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 p-8 opacity-10">
              <span class="text-[#00E5FF] font-['Caveat'] text-8xl">sys</span>
            </div>
            <div class="relative z-10">
              <div class="w-16 h-16 bg-black border-2 border-gray-700 rounded-xl flex items-center justify-center mb-8 group-hover:border-[#00E5FF] transition-colors">
                <svg class="w-8 h-8 text-[#00E5FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              </div>
              <h3 class="text-4xl font-black tracking-tighter mb-4 text-white">Custom <span class="text-[#00E5FF]">Software</span></h3>
              <p class="text-gray-400 text-lg mb-8">
                Bespoke internal tools, automation systems, and SaaS platforms engineered to accelerate distinct operational workflows.
              </p>
              <ul class="space-y-4 mb-8">
                <li class="flex items-center text-gray-300 font-medium"><span class="text-[#00E5FF] mr-3">&#10003;</span> Secure REST/GraphQL APIs</li>
                <li class="flex items-center text-gray-300 font-medium"><span class="text-[#00E5FF] mr-3">&#10003;</span> Complex Dashboards</li>
                <li class="flex items-center text-gray-300 font-medium"><span class="text-[#00E5FF] mr-3">&#10003;</span> Cloud & Backend Systems</li>
              </ul>
              <a href="/contact" class="inline-flex items-center font-bold pb-1 border-b-2 border-white hover:border-[#00E5FF] text-[#00E5FF] hover:text-white transition-colors">
                Request a Demo &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="py-24 bg-gray-50 border-t border-gray-100">
      <div class="container mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-black mb-4">Our Arsenal</h2>
          <div class="w-24 h-1 bg-[#00E5FF] mx-auto"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 text-center opacity-60">
          <div class="flex flex-col items-center justify-center grayscale hover:grayscale-0 hover:text-[#00E5FF] transition-all cursor-crosshair">
            <div class="text-2xl font-black uppercase tracking-widest mb-2">AWS</div>
            <p class="text-xs font-bold font-['Caveat'] text-gray-500">Cloud Native</p>
          </div>
          <div class="flex flex-col items-center justify-center grayscale hover:grayscale-0 hover:text-[#00E5FF] transition-all cursor-crosshair">
            <div class="text-2xl font-black uppercase tracking-widest mb-2">React</div>
            <p class="text-xs font-bold font-['Caveat'] text-gray-500">Frontend</p>
          </div>
          <div class="flex flex-col items-center justify-center grayscale hover:grayscale-0 hover:text-[#00E5FF] transition-all cursor-crosshair">
            <div class="text-2xl font-black uppercase tracking-widest mb-2">Python</div>
            <p class="text-xs font-bold font-['Caveat'] text-gray-500">Data & Backend</p>
          </div>
          <div class="flex flex-col items-center justify-center grayscale hover:grayscale-0 hover:text-[#00E5FF] transition-all cursor-crosshair">
            <div class="text-2xl font-black uppercase tracking-widest mb-2">Docker</div>
            <p class="text-xs font-bold font-['Caveat'] text-gray-500">Containers</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black text-white py-20 border-t-4 border-[#00E5FF] relative z-10">
      <div class="container mx-auto px-6 text-center">
        <div class="text-3xl font-bold mb-6">
          Horizon <span class="text-[#00E5FF] font-['Caveat'] text-4xl ml-1">-gh</span>
        </div>
        <p class="text-gray-400 mb-8 max-w-sm mx-auto">
          Engineering the next generation of web applications from the heart of America to the world.
        </p>
        <p class="text-sm text-gray-500">
          &copy; {new Date().getFullYear()} Horizon gh. All rights reserved.
        </p>
      </div>
    </footer>
  </div>
</Layout>
