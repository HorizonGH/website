---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content } = await render(post);
const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' });
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
---

<Layout title={`${post.data.title} | Horizon.gh`}>
  <!-- Top Navigation Bar -->
  <nav class="fixed top-0 w-full z-50 bg-gradient-to-b from-surface to-transparent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 sm:py-4 flex justify-between items-center">
      <div class="text-lg sm:text-2xl font-display font-bold tracking-tighter text-primary">Horizon.gh</div>
      <div class="hidden md:flex items-center gap-8 font-display tracking-tight">
        <a class="text-slate-300 hover:text-primary transition-colors" href="/">Home</a>
        <a class="text-slate-300 hover:text-primary transition-colors" href="/services">Services</a>
        <a class="text-primary border-b-2 border-primary pb-1" href="/blog">Blog</a>
        <a class="text-slate-300 hover:text-primary transition-colors" href="/contact">Contact</a>
      </div>
      <button class="hidden sm:block cta-gradient text-on-primary px-6 py-2 rounded-lg font-label font-bold scale-95 active:scale-90 transition-transform hover:opacity-80">
        Get Started
      </button>
    </div>
  </nav>
      <div class="flex items-center ml-4 z-50">
        <LanguageSwitcher currentUrl={Astro.url} />
      </div>

  <main class="pt-16 sm:pt-20 md:pt-32 pb-20 sm:pb-24">
    <header class="max-w-4xl mx-auto px-4 sm:px-6 mb-8 sm:mb-12">
      <div class="flex flex-wrap items-center gap-2 sm:gap-3 mb-6">
        <span class="px-3 sm:px-4 py-1 sm:py-1.5 rounded-full glass-panel text-tertiary text-xs font-bold tracking-widest uppercase">
          {post.data.category}
        </span>
        <span class="px-3 sm:px-4 py-1 sm:py-1.5 rounded-full glass-panel text-on-surface-variant text-xs font-label">
          {post.data.readTime}
        </span>
        <span class="text-on-surface-variant text-xs sm:text-sm font-label">
          {formatDate(post.data.date)}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl md:text-6xl font-display font-bold text-on-surface tracking-tight mb-6">
        {post.data.title}
      </h1>
      <p class="text-lg sm:text-xl text-on-surface-variant leading-relaxed">
        {post.data.excerpt}
      </p>
      <div class="flex items-center gap-3 mt-6">
        <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center text-primary font-display font-bold">
          {post.data.author.split(' ').map((word: any[]) => word[0]).join('')}
        </div>
        <div>
          <p class="text-on-surface font-display font-bold">{post.data.author}</p>
          <p class="text-sm text-on-surface-variant font-label">{post.data.category}</p>
        </div>
      </div>
    </header>

    <section class="max-w-5xl mx-auto px-6 mb-16">
      <div class="relative overflow-hidden rounded-3xl bg-surface-container-low">
        <img alt={post.data.title} class="w-full h-[420px] object-cover" src={post.data.coverImage} />
        <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/20 to-transparent"></div>
      </div>
    </section>

    <article class="max-w-3xl mx-auto px-6 blog-content">
      <Content />
    </article>
  </main>

  <footer class="w-full border-t border-slate-800/30 bg-surface">
    <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="text-xl font-bold text-primary mb-4 font-display">Horizon.gh</div>
        <p class="font-body text-sm text-slate-400 max-w-xs">
          Architecting the digital landscape with precision engineering and creative intuition.
        </p>
      </div>
      <div>
        <h4 class="text-on-surface font-label font-bold mb-4">Explore</h4>
        <div class="flex flex-col space-y-2">
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="/services">Services</a>
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="/blog">Insights</a>
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="/contact">Contact</a>
        </div>
      </div>
      <div>
        <h4 class="text-on-surface font-label font-bold mb-4">Legal</h4>
        <div class="flex flex-col space-y-2">
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="#">Privacy Policy</a>
          <a class="font-body text-sm text-slate-500 hover:text-tertiary transition-colors" href="#">Terms of Service</a>
        </div>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-6 py-8 border-t border-slate-800/20 text-center">
      <p class="font-body text-sm text-slate-400">© 2026 Horizon.gh. Engineering the Digital Horizon.</p>
    </div>
  </footer>
</Layout>

<style>
  .blog-content :global(h2) {
    margin: 2.5rem 0 1rem;
    font-size: 1.75rem;
    font-family: var(--font-display);
    color: var(--color-on-surface);
  }

  .blog-content :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.35rem;
    font-family: var(--font-display);
    color: var(--color-on-surface);
  }

  .blog-content :global(p) {
    margin: 0 0 1.25rem;
    line-height: 1.7;
    color: var(--color-on-surface-variant);
  }

  .blog-content :global(ul) {
    margin: 0 0 1.25rem 1.25rem;
    list-style: disc;
    color: var(--color-on-surface-variant);
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-content :global(a) {
    color: var(--color-primary);
  }
</style>
