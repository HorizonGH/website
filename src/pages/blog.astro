---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const rest = posts.filter((post) => post !== featured);
const categories = Array.from(
  new Set(posts.map((post) => post.data.category).filter(Boolean))
);
const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', day: '2-digit' });
---

<Layout title="Insights & Innovations | Horizon.gh" locale={locale}>
  <Navigation locale={locale} />

  <main class="pt-32 pb-24">
    <!-- Page Header -->
    <header class="max-w-7xl mx-auto px-6 mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-tertiary-container text-tertiary font-label text-xs font-bold uppercase tracking-widest mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-tertiary animate-pulse"></span>
        The Lab
      </div>
      <h1 class="text-6xl md:text-8xl font-display font-bold text-on-surface tracking-tighter mb-6 leading-tight">
        Insights & Innovations
      </h1>
      <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl font-light leading-relaxed">
        Expert perspectives on the future of technology and IT strategy. Engineering the digital horizon through deep technical analysis.
      </p>
    </header>

    <!-- Featured Article -->
    {featured && (
      <section class="max-w-7xl mx-auto px-6 mb-24">
        <article class="relative group overflow-hidden rounded-3xl bg-surface-container-low min-h-[600px] flex items-end">
          <div class="absolute inset-0 z-0">
            <img
              alt={featured.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              src={featured.data.coverImage}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface via-surface/40 to-transparent"></div>
          </div>
          <div class="relative z-10 p-8 md:p-16 max-w-4xl">
            <div class="flex gap-4 mb-6">
              <span class="px-4 py-1.5 rounded-full glass-panel text-primary font-label text-sm border border-outline-variant/20">
                Featured Analysis
              </span>
              <span class="px-4 py-1.5 rounded-full glass-panel text-on-surface-variant font-label text-sm">
                {featured.data.readTime}
              </span>
            </div>
            <h2 class="text-4xl md:text-6xl font-display font-bold text-on-surface mb-6 leading-[1.1] tracking-tight">
              {featured.data.title}
            </h2>
            <p class="text-lg md:text-xl text-on-surface-variant mb-8 font-body font-light">
              {featured.data.excerpt}
            </p>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center text-primary font-display font-bold">
                {featured.data.author.split(' ').map((word) => word[0]).join('')}
              </div>
              <div>
                <p class="font-display font-bold text-on-surface">{featured.data.author}</p>
                <p class="text-sm text-on-surface-variant font-label">
                  {featured.data.category} • {formatDate(featured.data.date)}
                </p>
              </div>
            </div>
            <a class="inline-flex items-center gap-2 text-primary font-label font-bold mt-6" href={`/blog/${featured.id}`}>
              Read the full analysis <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </article>
      </section>
    )}

    <!-- Categories & Filter -->
    <section class="max-w-7xl mx-auto px-6 mb-12 flex flex-wrap items-center gap-4">
      <button class="px-6 py-2.5 rounded-full bg-primary text-on-primary font-label font-bold text-sm transition-all">
        All Perspectives
      </button>
      {categories.map((category) => (
        <button class="px-6 py-2.5 rounded-full bg-surface-container-high text-on-surface-variant font-label font-medium text-sm hover:bg-surface-bright transition-all">
          {category}
        </button>
      ))}
    </section>

    <!-- Article Grid -->
    <section class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rest.map((post) => (
        <article class="group bg-surface-container-low rounded-2xl overflow-hidden hover:bg-surface-container transition-all duration-300 flex flex-col">
          <div class="h-56 overflow-hidden relative">
            <img
              alt={post.data.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              src={post.data.coverImage}
            />
            <span class="absolute top-4 left-4 px-3 py-1 rounded-full glass-panel text-tertiary text-[10px] font-bold tracking-widest uppercase">
              {post.data.category}
            </span>
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="text-2xl font-display font-bold text-on-surface mb-3 group-hover:text-primary transition-colors leading-snug">
              {post.data.title}
            </h3>
            <p class="text-on-surface-variant font-light text-sm mb-6">
              {post.data.excerpt}
            </p>
            <div class="mt-auto flex items-center justify-between border-t border-outline-variant/20 pt-6">
              <div class="flex items-center gap-2">
                <span class="text-xs font-label text-slate-400">
                  {post.data.author} • {formatDate(post.data.date)}
                </span>
              </div>
              <a class="inline-flex items-center gap-1 text-primary font-label font-bold text-sm" href={`/blog/${post.id}`}>
                Read More
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Newsletter Subscription -->
    <section class="max-w-7xl mx-auto px-6 mt-32">
      <div class="bg-surface-container-highest rounded-[40px] p-12 md:p-24 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-primary/5 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
        <div class="max-w-3xl relative z-10">
          <h2 class="text-4xl md:text-6xl font-display font-bold text-on-surface mb-6 tracking-tight">
            Stay ahead of the horizon.
          </h2>
          <p class="text-xl text-on-surface-variant mb-12 font-light leading-relaxed">
            Join 10,000+ technology leaders who receive our monthly breakdown of emerging tech, IT strategy, and engineering best practices.
          </p>
          <form class="flex flex-col md:flex-row gap-4">
            <input
              class="flex-grow bg-surface-container-low border-none rounded-2xl px-6 py-4 text-on-surface focus:ring-2 focus:ring-primary transition-all placeholder:text-slate-500 font-label"
              placeholder="Enter your work email"
              type="email"
            />
            <button class="bg-primary text-on-primary font-label font-bold px-10 py-4 rounded-2xl hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary/20" type="submit">
              Subscribe
            </button>
          </form>
          <p class="mt-6 text-sm text-slate-500 font-label">
            Unsubscribe anytime. Your data is protected under our <a class="underline hover:text-primary transition-colors" href="#">Privacy Policy</a>.
          </p>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="w-full border-t border-slate-800/30 bg-surface">
    <div class="max-w-7xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-1">
        <div class="text-xl font-bold text-primary mb-4 font-display">Horizon.gh</div>
        <p class="font-body text-sm text-slate-400 leading-relaxed">
          Engineering the digital horizon through high-performance IT solutions and strategic innovation.
        </p>
      </div>
      <div>
        <h4 class="text-primary font-display font-bold mb-6">Expertise</h4>
        <ul class="space-y-3 font-body text-sm text-slate-400">
          <li><a class="hover:text-tertiary transition-colors" href="#">Cloud Migration</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">AI Implementation</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">Cybersecurity Strategy</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">DevOps Excellence</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-primary font-display font-bold mb-6">Resources</h4>
        <ul class="space-y-3 font-body text-sm text-slate-400">
          <li><a class="hover:text-tertiary transition-colors text-primary" href="/blog">Insights & Blog</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">White Papers</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">Case Studies</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">Tech Documentation</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-primary font-display font-bold mb-6">Legal</h4>
        <ul class="space-y-3 font-body text-sm text-slate-400">
          <li><a class="hover:text-tertiary transition-colors" href="#">Privacy Policy</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">Terms of Service</a></li>
          <li><a class="hover:text-tertiary transition-colors" href="#">Security Compliance</a></li>
        </ul>
      </div>
    </div>
    <div class="max-w-7xl mx-auto px-6 py-6 border-t border-slate-800/30 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-body text-sm text-slate-500">© 2024 Horizon.gh. Engineering the Digital Horizon.</p>
      <div class="flex gap-6">
        <a class="text-slate-500 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">brand_family</span></a>
        <a class="text-slate-500 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">share</span></a>
        <a class="text-slate-500 hover:text-primary transition-colors" href="#"><span class="material-symbols-outlined">alternate_email</span></a>
      </div>
    </div>
  </footer>
</Layout>
