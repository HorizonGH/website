---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' });
---

<Layout title="Blog | Horizon.gh" locale={locale}>
  <Navigation locale={locale} />

  <main class="pt-32 pb-24">
    <!-- Page Header -->
    <header class="max-w-7xl mx-auto px-6 mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-tertiary-container text-tertiary font-label text-xs font-bold uppercase tracking-widest mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-tertiary animate-pulse"></span>
        {t.blog.title}
      </div>
      <h1 class="text-6xl md:text-8xl font-display font-bold text-on-surface tracking-tighter mb-6 leading-tight">
        {t.blog.title}
      </h1>
      <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl font-light leading-relaxed">
        {t.blog.description}
      </p>
    </header>

    <!-- Articles Grid -->
    <section class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="group relative overflow-hidden rounded-2xl bg-surface-container-low hover:bg-surface-container transition-all duration-300 h-full flex flex-col">
            {post.data.coverImage && (
              <div class="h-48 overflow-hidden">
                <img
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  src={post.data.coverImage}
                />
              </div>
            )}
            <div class="p-8 flex flex-col flex-grow">
              <div class="flex gap-2 mb-4 flex-wrap">
                <span class="px-3 py-1 rounded-full bg-primary/20 text-primary font-label text-xs uppercase tracking-widest">
                  {post.data.category}
                </span>
                <span class="px-3 py-1 rounded-full bg-surface-container-highest text-on-surface-variant font-label text-xs">
                  {post.data.readTime}
                </span>
              </div>
              <h3 class="text-xl font-display font-bold text-on-surface mb-3 line-clamp-2 group-hover:text-primary transition-colors">
                {post.data.title}
              </h3>
              <p class="text-sm text-on-surface-variant mb-4 flex-grow line-clamp-2">
                {post.data.excerpt}
              </p>
              <div class="flex items-center justify-between pt-4 border-t border-outline-variant/20">
                <span class="text-xs text-on-surface-variant font-label">
                  {formatDate(post.data.date)}
                </span>
                <a href={`/blog/${post.id}`} class="text-primary font-label font-bold text-xs hover:gap-2 transition-all group/link">
                  {t.blog.readMore} →
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
